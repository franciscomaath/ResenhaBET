{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data-display/**",
              "components/feedback/**",
              "ui_kits/mobile-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Inter Tight|Material Icons))/i]",
        "message": "Font not provided by the design system. Available: Inter, Inter Tight, Material Icons."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|loading|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, loading, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:elevated|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: elevated, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|subtitle|children|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, subtitle, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Fab'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|key|ref|className|style|children)$/]",
        "message": "<Fab> doesn't accept that prop. Declared props: icon, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:invalid|prefix|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: invalid, prefix."
      },
      {
        "selector": "JSXOpeningElement[name.name='LoadingSkeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:rows|height|style|key|ref|className|style|children)$/]",
        "message": "<LoadingSkeleton> doesn't accept that prop. Declared props: rows, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoneyValue'] > JSXAttribute > JSXIdentifier[name!=/^(?:amount|tone|size|prefix|style|key|ref|className|style|children)$/]",
        "message": "<MoneyValue> doesn't accept that prop. Declared props: amount, tone, size, prefix, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OddButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|odd|tone|selected|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<OddButton> doesn't accept that prop. Declared props: label, odd, tone, selected, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OddButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:team|draw)$/]",
        "message": "<OddButton> tone must be one of 'team' | 'draw'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RankRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:rank|name|value|valueColor|highlight|style|key|ref|className|style|children)$/]",
        "message": "<RankRow> doesn't accept that prop. Declared props: rank, name, value, valueColor, highlight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoleChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|key|ref|className|style|children)$/]",
        "message": "<RoleChip> doesn't accept that prop. Declared props: role."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|actionLabel|onAction|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: label, actionLabel, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|valueColor|style|key|ref|className|style|children)$/]",
        "message": "<StatCell> doesn't accept that prop. Declared props: label, value, valueColor, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StateBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|message|children|style|key|ref|className|style|children)$/]",
        "message": "<StateBanner> doesn't accept that prop. Declared props: type, message, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StateBanner'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:error|warn|info)$/]",
        "message": "<StateBanner> type must be one of 'error' | 'warn' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|style|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: tone, dot, children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
